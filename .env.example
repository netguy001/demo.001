# AlphaSync Environment Configuration
# Copy this file to .env and update values

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://alphasync:alphasync@localhost:5432/alphasync

# JWT Security
JWT_SECRET_KEY=dev-secret-key-not-for-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Virtual Capital (INR)
DEFAULT_VIRTUAL_CAPITAL=1000000.0

# Market Data
MARKET_DATA_CACHE_SECONDS=15
PRICE_STREAM_INTERVAL=3.0

# Frontend Firebase (Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
 