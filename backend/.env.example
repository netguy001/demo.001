# ── AlphaSync Environment Configuration ─────────────────────────
# Copy this file to .env and fill in your values.

# ── Core ────────────────────────────────────────────────────────
APP_NAME=AlphaSync
# Keep DEBUG=false in any internet-facing environment.
# For localhost-only development you may set DEBUG=true.
DEBUG=false
DATABASE_URL=postgresql+asyncpg://alphasync:alphasync@localhost:5432/alphasync
BROKER_ENCRYPTION_KEY=dev-broker-key-not-for-production-needs-32chars!!

# ── Firebase Authentication ─────────────────────────────────────
# Provide one of the following:
# FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_JSON=

# ── CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Redis (shared live price cache across all user sessions) ────
REDIS_URL=redis://localhost:6379/0

# ── Zebu / MYNT Market Data Feed ────────────────────────────────
ZEBU_WS_URL=wss://go.mynt.in/NorenWSTP/
ZEBU_API_SECRET=
STRICT_ZEBU_MARKET_DATA=false

# ── Zebu Broker OAuth (per-user authentication) ────────────────
ZEBU_VENDOR_CODE=
ZEBU_REDIRECT_URI=http://localhost:5173/broker/callback
ZEBU_API_URL=https://go.mynt.in/NorenWClientTP

# ── Master Zebu Session (shared live feed at startup) ───────────
ZEBU_MASTER_USER_ID=
ZEBU_MASTER_PASSWORD=
ZEBU_MASTER_DOB=

# ── Simulation ──────────────────────────────────────────────────
SIMULATION_MODE=true

# ── Admin Panel Security ────────────────────────────────────────
ADMIN_SESSION_EXPIRY_MINUTES=30
TOTP_ISSUER_NAME=AlphaSync Admin
# JSON array of bootstrap admin emails
ADMIN_EMAIL_ALLOWLIST=["meganath1025@gmail.com"]

# ── SMTP (Account Notifications) ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@alphasync.app
SMTP_FROM_NAME=AlphaSync
SMTP_USE_TLS=true
